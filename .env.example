# LLM provider credentials used by the `openai-agents` runtime.
# Required for pipeline analysis runs from the CLI or Next.js UI.
OPENAI_API_KEY=your_api_key_here

# Optional: use an OpenAI-compatible base URL instead of the default provider endpoint.
OPENAI_BASE_URL=

# Optional: default model used by the shared OpenAI-compatible agent model factory.
OPENAI_MODEL=gpt-4.1-mini

# Optional: runtime directories.
DATA_DIR=data
REPORTS_DIR=data/reports
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
TRANSCRIPTS_DIR=data/transcripts

# Optional: API runtime settings.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ENVIRONMENT=development

# Optional: route transcript requests through Webshare to reduce YouTube IP blocking.
ENABLE_WEBSHARE_PROXY=false
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
